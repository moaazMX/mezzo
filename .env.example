# Supabase Configuration
# Get these values from Supabase Dashboard: https://app.supabase.com
# After creating a new project in Supabase, go to Settings > API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Instructions:
# 1. Copy this file and rename it to .env (without .example)
# 2. Replace the values above with your actual Supabase values
# 3. Make sure the .env file is in the project root directory
# 4. Restart the dev server after adding the variables
